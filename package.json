{
  "name": "lovely-chart",
  "version": "2.0.0",
  "description": "A tiny, dependency-free library for beautiful interactive charts: line, area, bar, step, pie and donut, with smooth animations, a draggable minimap and drill-down zooming",
  "type": "module",
  "main": "./dist/LovelyChart.js",
  "types": "./dist/LovelyChart.d.ts",
  "exports": {
    ".": {
      "types": "./dist/LovelyChart.d.ts",
      "default": "./dist/LovelyChart.js"
    },
    "./LovelyChart.css": "./dist/LovelyChart.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "dev": "npm run demo && vite docs",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "npm run typecheck && npm run lint && npm run build && node test/e2e.js",
    "prepublishOnly": "npm run build",
    "demo": "npm run build && cp ./dist/LovelyChart.js ./dist/LovelyChart.css docs/",
    "prepare": "(husky || true) && npm run build"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^4.4.1",
    "cssnano": "^4.1.11",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright-core": "^1.60.0",
    "sass": "^1.83.0",
    "stylelint": "^17.1.1",
    "stylelint-config-clean-order": "^8.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Ajaxy/lovely-chart.git"
  },
  "keywords": [
    "chart",
    "graph",
    "plot",
    "canvas",
    "typescript",
    "lightweight",
    "interactive",
    "line",
    "area",
    "bar",
    "pie",
    "donut",
    "telegram"
  ],
  "author": "Alexander Zinchuk",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ajaxy/lovely-chart/issues"
  },
  "homepage": "https://github.com/Ajaxy/lovely-chart#readme"
}
